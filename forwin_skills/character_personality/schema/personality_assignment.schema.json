{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForWin Personality Assignment Report v1",
  "type": "object",
  "required": ["assignment_id", "policy_version", "assignment_mode", "confidence", "status"],
  "properties": {
    "assignment_id": { "type": "string" },
    "policy_version": { "type": "string" },
    "assignment_mode": { "type": "string" },
    "source": { "type": "string" },
    "source_ref": { "type": "string" },
    "assigned_at": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "type": "string" },
    "manual_override": { "type": "boolean" },
    "preserved_existing_loadout": { "type": "boolean" },
    "selected_skills": { "type": "array", "items": { "type": "object" } },
    "candidate_skills": { "type": "array", "items": { "type": "object" } },
    "rejected_skills": { "type": "array", "items": { "type": "object" } },
    "signal_summary": { "type": "object" },
    "reason_tags": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "compatibility_warnings": { "type": "array", "items": { "type": "string" } },
    "diversity_adjustments": { "type": "array", "items": { "type": "object" } },
    "selected_secondary": { "type": "array", "items": { "type": "object" } },
    "diff": { "type": "object" },
    "diff_refs": { "type": "array", "items": { "type": "string" } },
    "explain": { "type": "object" },
    "decision_events": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
