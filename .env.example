# ---------------------------------------------------------------------
# ForWin personal-server deployment
# ---------------------------------------------------------------------
FORWIN_HTTP_BIND=127.0.0.1
FORWIN_HTTP_PORT=8899
# FORWIN_HTTP_BASIC_USER=
# FORWIN_HTTP_BASIC_PASSWORD=

# ---------------------------------------------------------------------
# Core data paths
# ---------------------------------------------------------------------
FORWIN_DB_PATH=data/novel.db
FORWIN_ARTIFACT_BACKEND=local
FORWIN_ARTIFACT_ROOT=data/artifacts
FORWIN_RUNTIME_SETTINGS_PATH=data/runtime_settings.json

# ---------------------------------------------------------------------
# LLM providers
# ---------------------------------------------------------------------
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---------------------------------------------------------------------
# Generation tuning
# ---------------------------------------------------------------------
LLM_TIMEOUT_SECONDS=90
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_INITIAL_DELAY_SECONDS=2
LLM_RETRY_MAX_DELAY_SECONDS=15
DEFAULT_SCENE_COUNT=3
MAX_SCENE_COUNT=4
MAX_CHAPTER_CHARS=3200
MIN_CHAPTER_CHARS=2500
TARGET_CHAPTER_CHARS=2800
WRITER_MODE=scene
OPERATION_MODE=blackbox

# ---------------------------------------------------------------------
# Retrieval
# ---------------------------------------------------------------------
FORWIN_RETRIEVAL_BACKEND=local
FORWIN_RETRIEVAL_ROOT=data/retrieval
FORWIN_QDRANT_URL=http://qdrant:6333
FORWIN_QDRANT_COLLECTION=chapter_memories

# ---------------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------------
FORWIN_EMBEDDING_BACKEND=hash
FORWIN_EMBEDDING_BASE_URL=https://api.minimaxi.com/v1
FORWIN_EMBEDDING_API_KEY=
FORWIN_EMBEDDING_MODEL=
FORWIN_EMBEDDING_DIMS=64

# ---------------------------------------------------------------------
# MinIO artifacts, only needed when FORWIN_ARTIFACT_BACKEND=minio
# ---------------------------------------------------------------------
FORWIN_MINIO_ENDPOINT=minio:9000
FORWIN_MINIO_ACCESS_KEY=replace-with-minio-access-key
FORWIN_MINIO_SECRET_KEY=replace-with-long-random-minio-secret
FORWIN_MINIO_BUCKET=forwin-artifacts
FORWIN_MINIO_PREFIX=artifacts
FORWIN_MINIO_SECURE=false

# ---------------------------------------------------------------------
# Publisher extension
# ---------------------------------------------------------------------
FORWIN_PUBLISHER_EXTENSION_API_KEY=replace-with-random-extension-token
FORWIN_PUBLISHER_PREFERRED_CLIENT_ID=

# ---------------------------------------------------------------------
# Publisher browser container
# ---------------------------------------------------------------------
FORWIN_EXTENSION_TEST_PROFILE=/app/data/chrome_profiles/forwin-extension
FORWIN_EXTENSION_TEST_REMOTE_DEBUGGING_PORT=9222
FORWIN_EXTENSION_TEST_REMOTE_DEBUGGING_ADDRESS=0.0.0.0
FORWIN_EXTENSION_DISPLAY_MODE=auto
FORWIN_EXTENSION_DISPLAY=:100
FORWIN_EXTENSION_XVFB_SERVER_NUM=100
FORWIN_EXTENSION_NO_SANDBOX=auto
FORWIN_EXTENSION_STARTUP_HEARTBEAT_TIMEOUT_SECONDS=75
FORWIN_EXTENSION_DEBUG_BIND=127.0.0.1:9222

# ---------------------------------------------------------------------
# Codex bridge
# ---------------------------------------------------------------------
FORWIN_CODEX_ENABLED=false
FORWIN_CODEX_BRIDGE_URL=http://host.docker.internal:8897
FORWIN_CODEX_BRIDGE_TOKEN=
FORWIN_CODEX_MAX_CONCURRENT=1
FORWIN_CODEX_SYNC_TIMEOUT_SECONDS=90
FORWIN_CODEX_JOB_TIMEOUT_SECONDS=900
