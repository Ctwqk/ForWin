# ---------------------------------------------------------------------
# ForWin personal-server deployment
# ---------------------------------------------------------------------
# Localhost-only access is the safest default.
FORWIN_HTTP_BIND=127.0.0.1
FORWIN_HTTP_PORT=8899

# LAN access: set this to your server's fixed LAN IP, for example 192.168.1.10.
# Do not use 0.0.0.0 unless you explicitly want every interface to listen.
# FORWIN_HTTP_BIND=192.168.1.10
# FORWIN_HTTP_PORT=8899
# FORWIN_ALLOW_UNAUTHENTICATED_LAN=false
# FORWIN_ALLOW_BIND_ALL_INTERFACES=false

# Optional for localhost. Required when FORWIN_HTTP_BIND is a LAN/non-localhost address
# unless FORWIN_ALLOW_UNAUTHENTICATED_LAN=true is explicitly set.
FORWIN_HTTP_BASIC_USER=
FORWIN_HTTP_BASIC_PASSWORD=

# External service image tags are pinned but still overridable.
QDRANT_IMAGE_TAG=v1.17.1
MINIO_IMAGE_TAG=RELEASE.2025-09-07T16-13-09Z
FORWIN_QDRANT_DEBUG_BIND=127.0.0.1:6335
FORWIN_MCP_DEBUG_BIND=127.0.0.1:8896
FORWIN_MCP_PORT=8896
FORWIN_MCP_API_TIMEOUT_SECONDS=300

# ---------------------------------------------------------------------
# Core data paths
# ---------------------------------------------------------------------
FORWIN_DATABASE_URL=postgresql+psycopg://forwin:forwin@postgres:5432/forwin
FORWIN_TEST_DATABASE_URL=postgresql+psycopg://forwin:forwin@127.0.0.1:55432/forwin_test
FORWIN_ARTIFACT_BACKEND=local
FORWIN_ARTIFACT_ROOT=data/artifacts
FORWIN_RUNTIME_SETTINGS_PATH=data/runtime_settings.json

# ---------------------------------------------------------------------
# LLM providers
# ---------------------------------------------------------------------
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---------------------------------------------------------------------
# Generation tuning
# ---------------------------------------------------------------------
LLM_TIMEOUT_SECONDS=90
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_INITIAL_DELAY_SECONDS=2
LLM_RETRY_MAX_DELAY_SECONDS=15
DEFAULT_SCENE_COUNT=3
MAX_SCENE_COUNT=4
MAX_CHAPTER_CHARS=3200
MIN_CHAPTER_CHARS=2500
TARGET_CHAPTER_CHARS=2800
WRITER_MODE=scene
OPERATION_MODE=blackbox

# ---------------------------------------------------------------------
# Retrieval
# ---------------------------------------------------------------------
FORWIN_RETRIEVAL_BACKEND=qdrant
FORWIN_RETRIEVAL_ROOT=data/retrieval
FORWIN_QDRANT_URL=http://qdrant:6333
FORWIN_QDRANT_COLLECTION=chapter_memories
FORWIN_LLM_KB_QDRANT_COLLECTION=llm_kb_vectors

# ---------------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------------
FORWIN_EMBEDDING_BACKEND=hash
FORWIN_EMBEDDING_BASE_URL=https://api.minimaxi.com/v1
FORWIN_EMBEDDING_API_KEY=
FORWIN_EMBEDDING_MODEL=
FORWIN_EMBEDDING_DIMS=64

# ---------------------------------------------------------------------
# MinIO artifacts, only needed when FORWIN_ARTIFACT_BACKEND=minio
# ---------------------------------------------------------------------
FORWIN_MINIO_ENDPOINT=minio:9000
FORWIN_MINIO_ACCESS_KEY=replace-with-minio-access-key
FORWIN_MINIO_SECRET_KEY=replace-with-long-random-minio-secret
FORWIN_MINIO_BUCKET=forwin-artifacts
FORWIN_MINIO_PREFIX=artifacts
FORWIN_MINIO_SECURE=false

# ---------------------------------------------------------------------
# Publisher extension
# ---------------------------------------------------------------------
# Publisher extension API key used by the browser extension to call ForWin.
FORWIN_PUBLISHER_EXTENSION_API_KEY=change-me-random-token

# Required when FORWIN_PUBLISHER_EXTENSION_API_KEY is set. Encrypts stored
# publisher browser cookies/sessions; replace the placeholder before enabling.
FORWIN_PUBLISHER_SESSION_SECRET=replace-with-long-random-secret
FORWIN_PUBLISHER_SESSION_ENCRYPTION_REQUIRED=true
FORWIN_PUBLISHER_PREFERRED_CLIENT_ID=

# Optional. Leave unset for the shared production Swarm deployment. If a trusted
# private deployment deliberately wants out-of-band scan-login alerts, the
# browser extension can forward a fresh QR image to Discord through the backend.
# Use the _FILE variant only for that trusted deployment so the webhook is
# supplied by Docker/Kubernetes secrets or another mounted secret file.
FORWIN_PUBLISHER_LOGIN_DISCORD_WEBHOOK_URL=
FORWIN_PUBLISHER_LOGIN_DISCORD_WEBHOOK_FILE=

# Compatibility/debug only. Leave disabled for normal writing.
FORWIN_WORLD_V4_COMPAT_WRITE=false
FORWIN_ENABLE_COMPAT_DEBUG_API=false

# ---------------------------------------------------------------------
# Publisher browser container
# ---------------------------------------------------------------------
FORWIN_EXTENSION_TEST_PROFILE=/app/data/chrome_profiles/forwin-extension
FORWIN_EXTENSION_TEST_REMOTE_DEBUGGING_PORT=9222
FORWIN_EXTENSION_TEST_REMOTE_DEBUGGING_ADDRESS=0.0.0.0
FORWIN_EXTENSION_DISPLAY_MODE=auto
FORWIN_EXTENSION_DISPLAY=:100
FORWIN_EXTENSION_XVFB_SERVER_NUM=100
FORWIN_EXTENSION_NO_SANDBOX=auto
FORWIN_EXTENSION_STARTUP_HEARTBEAT_TIMEOUT_SECONDS=75
FORWIN_EXTENSION_DEBUG_BIND=127.0.0.1:9222

# ---------------------------------------------------------------------
# Codex bridge
# ---------------------------------------------------------------------
FORWIN_CODEX_ENABLED=false
FORWIN_CODEX_BRIDGE_URL=http://host.docker.internal:8897
FORWIN_CODEX_BRIDGE_TOKEN=
FORWIN_CODEX_MAX_CONCURRENT=1
FORWIN_CODEX_SYNC_TIMEOUT_SECONDS=90
FORWIN_CODEX_JOB_TIMEOUT_SECONDS=900
