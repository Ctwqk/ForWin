# Localhost-only access is the safest default.
FORWIN_HTTP_BIND=127.0.0.1
FORWIN_HTTP_PORT=8899

# LAN access: set this to your server's fixed LAN IP, for example 192.168.1.10.
# Do not use 0.0.0.0 unless you explicitly want every interface to listen.
# FORWIN_HTTP_BIND=192.168.1.10
# FORWIN_HTTP_PORT=8899

# Optional single-user HTTP Basic Auth. Leave both blank to disable.
FORWIN_HTTP_BASIC_USER=
FORWIN_HTTP_BASIC_PASSWORD=

# Required for Docker Compose when MinIO is enabled.
FORWIN_MINIO_ACCESS_KEY=change-me
FORWIN_MINIO_SECRET_KEY=change-me-long-random-password

# External service image tags are pinned but still overridable.
QDRANT_IMAGE_TAG=v1.15.4
MINIO_IMAGE_TAG=RELEASE.2025-09-07T16-13-09Z

MINIMAX_API_KEY=your-minimax-api-key
FORWIN_PUBLISHER_EXTENSION_API_KEY=your-extension-api-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_INITIAL_DELAY_SECONDS=2
LLM_RETRY_MAX_DELAY_SECONDS=15
FORWIN_EXTENSION_TEST_PROFILE=data/chrome_profiles/forwin-extension-test
FORWIN_EXTENSION_TEST_REMOTE_DEBUGGING_PORT=9222
FORWIN_EXTENSION_DISPLAY_MODE=auto
FORWIN_EXTENSION_DISPLAY=:100
FORWIN_EXTENSION_XVFB_SERVER_NUM=100
